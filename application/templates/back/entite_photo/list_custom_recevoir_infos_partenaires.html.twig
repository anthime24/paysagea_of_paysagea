{% extends 'SonataAdminBundle:CRUD:base_list_field.html.twig' %}

{% block field %}
    <div>
        {% for creation in object.getCreations() %}
            {% if creation.getProjet().getRecevoirInfosPartenaires() is null %}

            {% elseif creation.getProjet().getRecevoirInfosPartenaires() %}
                <span class="label label-success">oui</span>
            {% else %}
                <span class="label label-danger">non</span>
            {% endif %}
        {% endfor %}
    </div>
{% endblock %}

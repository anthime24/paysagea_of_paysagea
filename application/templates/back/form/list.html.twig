{% block mjmt_list_type_widget %}
    {% spaceless %}
        {% if expanded %}
            <ul {{ block('widget_container_attributes') }}>
                {% for child in form %}
                    <li class="mjmt_list_type_row">
                        <a class="mjmt_list_type_a"
                           href="{{ path('admin_mjmt_back_projet_edit', {id: child.vars.value}) }}">{{ form_label(child) }}</a>
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            {# laisse le widget choice afficher la balise select #}
            {{ block('choice_widget') }}
        {% endif %}
    {% endspaceless %}
{% endblock %}

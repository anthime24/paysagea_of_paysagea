{% extends 'SonataAdminBundle::standard_layout.html.twig' %}

{% block title %}
    {# NEXT_MAJOR: remove default filter #}
    {% if objectId|default(admin.id(object)) is not null %}
        {{ "title_edit"|trans({'%name%': admin.toString(object)|truncate(15) }, 'SonataAdminBundle') }}
    {% else %}
        {{ "title_create"|trans({}, 'SonataAdminBundle') }}
    {% endif %}
{% endblock %}

{% block navbar_title %}
    {{ block('title') }}
{% endblock %}

{%- block actions -%}
    {% include 'SonataAdminBundle:CRUD:action_buttons.html.twig' %}
{%- endblock -%}

{% block mjmt_translated_type_label %}
    <div class="translatedLabel">
        <label>{{ form.vars.label }}</label>
        <span class="translatedButton">
            <i class="fa fa-language"></i>
            {% if translatedPropertyOriginalValue is defined %}
                <a data-content="{{ translatedPropertyOriginalValue }}" class="translatedButtonOriginalValue">voir valeur fr</a>
            {% endif %}
        </span>
    </div>
{% endblock %}

{% block tab_menu %}{{ knp_menu_render(admin.sidemenu(action), {'currentClass' : 'active', 'template': sonata_admin.adminPool.getTemplate('tab_menu_template')}, 'twig') }}{% endblock %}

{#{% use 'SonataAdminBundle:CRUD:base_edit_form.html.twig' with form as parentForm %}#}
{% use 'back/composition/base_edit_form.html.twig' with form as parentForm %}


{% form_theme form _self 'back/form/translatedField.html.twig' %}

{% block form %}
    {{ block('parentForm') }}
{% endblock %}
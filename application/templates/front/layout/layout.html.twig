    {% block meta %}
        <meta name="description" content="Mon Jardin Ma Terrasse"/>
    {% endblock %}
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <meta name="p:domain_verify" content="3a7e13181547ccd06198a65beaec944d"/>
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico"/>
    <link rel="stylesheet" type="text/css" media="all"
          href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.5/css/bootstrap.min.css"/>
    {% block stylesheets %}
        {{ encore_entry_link_tags('front') }}
    {% endblock %}

    {% if not is_app_domain() %}
    <!-- Start of  Zendesk Widget script -->
    <script id="ze-snippet" src="https://static.zdassets.com/ekr/snippet.js?key=489f5e93-6393-4e72-9d38-da66f0b539db"> </script>
    <!-- End of  Zendesk Widget script -->
    {% endif %}

    <script src="/tarteaucitron/tarteaucitron.js"></script>
    <script type="text/javascript">
        var tarteaucitronForceExpire = 182;

        if(tarteaucitron){
            tarteaucitron.events.load = function(){


                var DOMReadyTimeoutDuration = 500;
                setTimeout(function(){
                    // if user choose to personalize cookies management, we prevent "AllDeny" method execution
                    tarteaucitron.addClickEventToId("tarteaucitronCloseAlert", function () {
                        if(tarteaucitronDeniedAllTimeout) clearTimeout(tarteaucitronDeniedAllTimeout);
                    });
                    tarteaucitron.addClickEventToId("tarteaucitronPersonalize2", function () {
                        if(tarteaucitronDeniedAllTimeout) clearTimeout(tarteaucitronDeniedAllTimeout);
                    });

                    var tarteaucitronAlertBig= document.getElementById('tarteaucitronAlertBig');

                    if(tarteaucitronAlertBig){
                        tarteaucitronAlertBig.addEventListener('mouseenter', function () {
                            if(tarteaucitronDeniedAllTimeout) clearTimeout(tarteaucitronDeniedAllTimeout);
                        });
                    }
                }, DOMReadyTimeoutDuration);

                var tarteaucitronDeniedAllTimeoutSetter = function(){
                    return setTimeout(function(){
                        if(Object.keys(tarteaucitron.state).length == 0 || Object.keys(tarteaucitron.state).every(k => !tarteaucitron.state[k])){ // if user never responds to consent panel
                            tarteaucitron.userInterface.respondAll(false); // After a short duration, all non-necessary cookie are denied
                        }
                    }, (30 * 1000) + DOMReadyTimeoutDuration);
                }
                window.tarteaucitronDeniedAllTimeout = tarteaucitronDeniedAllTimeoutSetter();
            }
        }

        tarteaucitron.init({
            "privacyUrl": "", /* Privacy policy url */
            "bodyPosition": "bottom", /* or top to bring it as first element for accessibility */

            "hashtag": "#tarteaucitron", /* Open the panel with this hashtag */
            "cookieName": "tarteaucitron", /* Cookie name */

            "orientation": "middle", /* Banner position (top - bottom) */

            "groupServices": false, /* Group services by category */
            "serviceDefaultState": "wait", /* Default state (true - wait - false) */

            "showAlertSmall": false, /* Show the small banner on bottom right */
            "cookieslist": false, /* Show the cookie list */

            "closePopup": false, /* Show a close X on the banner */

            "showIcon": true, /* Show cookie icon to manage cookies */
            //"iconSrc": "", /* Optionnal: URL or base64 encoded image */
            "iconPosition": "BottomRight", /* BottomRight, BottomLeft, TopRight and TopLeft */

            "adblocker": false, /* Show a Warning if an adblocker is detected */

            "DenyAllCta" : true, /* Show the deny all button */
            "AcceptAllCta" : true, /* Show the accept all button when highPrivacy on */
            "highPrivacy": true, /* HIGHLY RECOMMANDED Disable auto consent */

            "handleBrowserDNTRequest": false, /* If Do Not Track == 1, disallow all */

            "removeCredit": false, /* Remove credit link */
            "moreInfoLink": true, /* Show more info link */

            "useExternalCss": false, /* If false, the tarteaucitron.css file will be loaded */
            "useExternalJs": false, /* If false, the tarteaucitron.js file will be loaded */

            //"cookieDomain": ".my-multisite-domaine.fr", /* Shared cookie for multisite */

            "readmoreLink": "", /* Change the default readmore link */

            "mandatory": true, /* Show a message about mandatory cookies */
            "mandatoryCta": true /* Show the disabled accept button when mandatory on */
        });
    </script>

    <!-- Google Tag Manager -->
    <script type="text/javascript">
        tarteaucitron.user.googletagmanagerId = 'UA-45291086-3';
        (tarteaucitron.job = tarteaucitron.job || []).push('googletagmanager');
    </script>
    <!-- End Google Tag Manager -->
</head>

<body id="body{% if app.request.attributes.get('_route') == 'mjmt_front_home' %}-home{% endif %}">

<!--Script google analytics visiplus -->
{% if app.request.getLocale() is defined and app.request.getLocale() is not null and app.request.getLocale() == 'en' %}
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=UA-45291086-3"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'UA-45291086-3');
    </script>
{% else %}
    <script>
        (function (i, s, o, g, r, a, m) {
            i['GoogleAnalyticsObject'] = r;
            i[r] = i[r] || function () {
                (i[r].q = i[r].q || []).push(arguments)
            }, i[r].l = 1 * new Date();
            a = s.createElement(o),
                m = s.getElementsByTagName(o)[0];
            a.async = 1;
            a.src = g;
            m.parentNode.insertBefore(a, m)
        })(window, document, 'script', '//www.google-analytics.com/analytics.js', 'ga');

        ga('create', 'UA-45291086-1', 'monjardin-materrasse.com');
        ga('send', 'pageview');
    </script>
    <!--END Script google analytics visiplus -->
{% endif %}


{% extends 'front/layout/layout.html.twig' %}

{% block javascripts %}
    {{ parent() }}

    <script type="text/javascript">
        jQuery(document).ready(function(){
            var stripe = Stripe(stripePublicKey);
            var $checkoutButton =  jQuery('#stripe-checkout-button');

            jQuery.ajax({
                'url': '/paiement/stripe-checkout',
                'method': 'POST',
                'dataType': 'json',
                'success': function(data) {
                    return stripe.redirectToCheckout({sessionId: data['sessionId']});
                }
            });
        });
    </script>
{% endblock %}

{% block content %}
    <script src="https://js.stripe.com/v3/"></script>
    <script type="text/javascript">
        var stripePublicKey = '{{ stripePublicKey }}';
    </script>

    <div id="page-payment-prepare" class="content-center container-fluid">
        <a class="pull-right button-validate-mini" href="{{ path('mjmt_front_client') }}"
           id="tableau-bord"><span>{% trans %}Revenir au tableau de bord{% endtrans %}</span></a>
        <h1 class="green">{% trans %}Paiement CB{% endtrans %}</h1>

        <div class="row">
            <div class="col-md-12 col-sm-12 col-xs-12">
                <p>{% trans %}Préparation du paiement en cours ...{% endtrans %}</p>
            </div>
    </div>
{% endblock %}

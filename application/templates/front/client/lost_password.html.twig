{% extends 'front/layout/layout.html.twig' %}

{% block content %}
    <div id="page-client-lost-password" class="content-center container-fluid">
        <h1 class="green">{% trans %}J'ai oublié mon mot de passe{% endtrans %}</h1>

        <div class="row">
            <div class="col-md-12 col-sm-12 col-xs-12">
                {{ form_start(form) }}
                <p class="text-center">{% trans %}Un nouveau mot de passe vous sera envoyé par mail.{% endtrans %}</p>
                {{ form_widget(form) }}

                <button class="button-validate" type="submit"><span>{% trans %}Re-générer{% endtrans %}</span></button>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}

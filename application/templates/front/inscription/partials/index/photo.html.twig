<div class="content-center container-fluid" id="bloc-photos">
    <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12">
            <h3>
                {% trans %}Télécharger une photo de votre extérieur :{% endtrans %}

                {% if extraFormErrors|length > 0 and extraFormErrors.creditPhoto is defined %}
                    <span class="badge bg-success" id="affichage-credit-restant" style="font-weight: bold; color: #FFF;background: #b30000;"></span>
                {% else %}
                    <span class="badge" id="affichage-credit-restant" style="background: #448f25;"></span>
                {% endif %}
            </h3>
        </div>
    </div>

    <div id="mjmt_frontbundle_projet_inscription_one_page_photo_upl" class="row">
        <div class="col-md-6 col-sm-6 col-xs-12">
            <div class="control-group">
                {{ form_label(form.banquePhoto.file) }}
                <div class="controls">
                    {{ form_widget(form.banquePhoto.file) }}
                    {% if extraFormErrors|length > 0 and extraFormErrors.banquePhotoFile is defined %}
                        <span style="font-weight: bold; color:#b30000;">{{ extraFormErrors.banquePhotoFile }}</span>
                    {% endif %}
                </div>
                {{ form_errors(form.banquePhoto.file) }}
            </div>
        </div>

        <div class="col-md-6 col-sm-6 col-xs-12">
            <div class="form-group">
                {{ form_label(form.banquePhoto.nom) }}
                <div class="input-group">
                    <div class="input-group-addon">
                        <span class="glyphicon glyphicon-pencil" aria-hidden="true"></span>
                    </div>
                    {{ form_widget(form.banquePhoto.nom) }}
                </div>
                {{ form_errors(form.banquePhoto.nom) }}
            </div>
        </div>

        <div class="col-xs-12">
            <div class="bs-callout bs-callout-warning">
                <h4 class="text-help-photo-size">{% trans %}10 Mo maximum - Vous pouvez redimensionner votre image via ce site <a
                            href="https://picresize.com/"
                            target="_blank">www.picresize.com</a> ou en utilisant Paint.{% endtrans %}
                </h4>
            </div>
        </div>

{#        <div class="col-xs-12">#}
{#            {{ form_row(form.recevoirInfosPartenaires) }}#}
{#        </div>#}
    </div>
</div>
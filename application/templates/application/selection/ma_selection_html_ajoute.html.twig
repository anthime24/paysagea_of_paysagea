<div class="selection-entite" id="maSelection-entite-{{ entite.getId() }}-{{ timestamp }}">
    <input type="hidden" class="entite-id" value="{{ entite.getId() }}-{{ timestamp }}"/>

    {% if not entite.getLasso() %}
        <input type="hidden" class="selection-entite-prix"
               value="{% if entite.getPrixMini() %}{{ entite.getPrixMini() }}{% else %}0{% endif %}"/>
    {% endif %}
    <input type="hidden" class="entite-type-{{ entite.getId() }}-{{ timestamp }}"
           value="{{ entite.getEntiteType().getNom() }}"/>
    <div class="entite-image entite-clicable">
        <img src="{{ entitePhoto.getWebPath() | imagine_filter('thumb_app_ma_selection') }}" alt="{{ entite.getNom() }}"
             title="{{ entite.getNom() }}" onmousedown="return false" onmousemove="return false"/>
    </div>
    <div class="entite-action">
        <div class="entite-suppression"><img src="{{ asset('application/images/icone/supprimer.png') }}"
                                             class="ma-selection-tipsy"
                                             original-title="{% trans %}Supprimer{% endtrans %}"/></div>
        <div class="entite-description"><a onclick="return openPopinInfosEntite(this);"
                                           href="{{ path('mjmt_application_ma_selection_description', {'entiteId': entite.getId()}) }}"><img
                        src="{{ asset('application/images/icone/description.png') }}" hieght="24px"
                        class="ma-selection-tipsy" original-title="{% trans %}Informations{% endtrans %}"/></a></div>
        <div class="entite-visibilite"><img src="{{ asset('application/images/icone/masquer.png') }}"
                                            class="ma-selection-tipsy"
                                            original-title="{% trans %}Visibilité{% endtrans %}"/></div>

        {% if not entite.getLasso() %}
            <div class="entite-dupliquer"><a
                        href="{{ path('mjmt_application_ajout_html_entite', {'entiteId': entite.getId()}) }}"><img
                            src="{{ asset('application/images/icone/dubliquer.png') }}" class="ma-selection-tipsy"
                            original-title="{% trans %}Dupliquer{% endtrans %}"/></a></div>
        {% else %}
            <div class="entite-dupliquer hiddenIfLasso" style="display:none;"><a
                        href="{{ path('mjmt_application_ajout_html_entite', {'entiteId': entite.getId()}) }}"><img
                            src="{{ asset('application/images/icone/dubliquer.png') }}" class="ma-selection-tipsy"
                            original-title="{% trans %}Dupliquer{% endtrans %}"/></a></div>
        {% endif %}
    </div>
    <div class="entite-infos entite-clicable">
        <h2>{% if entite.getNomVernaculaire() %}{{ entite.getNomVernaculaire()|truncate(30, true, '...') }}{% else %}{{ entite.getNom() }}{% endif %}</h2>
        <span>
            {% if not entite.getLasso() %}
                {% if entite.getEntiteType().getId() == 1 %}
                    {{ entite.getHauteurPotAvecUnite() }}
                {% else %}
                    {{ entite.getDimensions() }}
                {% endif %}
                {% if entite.getComposition() %}{% if entite.getComposition().getTotal()>0 %}- {{ entite.getComposition().getTotal() }} €{% endif %}{% else %}{% if entite.getPrixMini() %}- {{ entite.getPrixMini() }} €{% endif %}{% endif %}
            {% endif %}
        </span>
    </div>
</div>
<div class="clear"></div>

    <h2>{% trans %}Rendu final{% endtrans %}</h2>
    <hr/>
    <p style="text-align:center;"><img
                src="{{ app.request.getSchemeAndHttpHost() ~ creation.getWebPathRenderedImage() }}"
                style="{{ pdfStyleForMaximumHeight(creation.getFullPathRenderedImage(), 145) }};"/></p>
